# ── Server ──────────────────────────────────────────
PORT=5000                              # Server port
NODE_ENV=development                   # Environment: development | production

# ── Database ────────────────────────────────────────
MONGO_URI=                             # MongoDB connection string (e.g. mongodb://localhost:27017/event-booking)

# ── Authentication ──────────────────────────────────
JWT_SECRET=                            # JWT signing secret (min 32 chars in production)
JWT_EXPIRE=7d                          # JWT token expiration (e.g. 7d, 24h)

# ── Client ──────────────────────────────────────────
CLIENT_URL=http://localhost:5173       # Frontend URL for CORS

# ── Email (SMTP) ───────────────────────────────────
SMTP_HOST=smtp.office365.com           # SMTP server host
SMTP_PORT=587                          # SMTP server port
SMTP_USER=                             # SMTP email address (required in production)
SMTP_PASS=                             # SMTP app password (required in production)
SMTP_FROM_NAME=EventBooking            # Sender display name

# ── File Upload ─────────────────────────────────────
UPLOAD_MAX_SIZE=5242880                # Max upload size in bytes (default: 5MB)

# ── Admin Seed ──────────────────────────────────────
ADMIN_SEED_EMAIL=                      # Admin user email for seed script
ADMIN_SEED_PASSWORD=                   # Admin user password for seed script
ADMIN_SEED_NAME=                       # Admin user display name for seed script
